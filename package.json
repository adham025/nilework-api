{
  "name": "nilework-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["schemas"],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "worker": "tsx watch src/worker.ts",
    "migrate": "node scripts/migrate.mjs",
    "seed": "node scripts/seed.mjs",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run build -w @nilework/schemas && npm run typecheck && npm run lint && npm run test && npm run build",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@nilework/schemas": "*",
    "@sentry/node": "^8.47.0",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "pg-boss": "^12.23.0",
    "postgres": "^3.4.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "fast-check": "^4.8.0",
    "jimp": "^1.6.1",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
