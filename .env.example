# Nilework API — environment template. Copy to .env (local) / set as Fly secrets (prod).
# .env is gitignored and must NEVER be committed (MASTER_PLAN §6.4).

# --- Core -------------------------------------------------------------------
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# --- Supabase (Project Settings → API) -------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Postgres direct/pooler connection (Settings → Database). Use the pooler in prod.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- Observability ----------------------------------------------------------
SENTRY_DSN=

# --- Email (Resend) — money/deadline notifications. Unset = in-app only. -----
RESEND_API_KEY=
RESEND_FROM=Nilework <noreply@nilework.com>

# --- Payments (Paymob, Egypt). Unset = dev checkout simulation. -------------
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# --- Phone OTP (CPaaS). "log" = code printed to the server log (dev). -------
OTP_PROVIDER=log
CEQUENS_API_KEY=
CEQUENS_SENDER=

# --- Live FX feed. Unset = keep the seeded placeholder rate. ----------------
FX_API_URL=
FX_API_KEY=
