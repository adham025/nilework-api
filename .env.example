# Nilework API — environment template. Copy to .env and fill real values.
# .env is gitignored and must NEVER be committed (MASTER_PLAN §6.4).

NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Supabase (Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Postgres direct/pooler connection (Project Settings → Database → Connection string).
# Use the connection-pooler URL for deployed environments.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Observability
SENTRY_DSN=

# Email (Resend)
RESEND_API_KEY=

# Comma-separated origins allowed to call the API (the web app).
CORS_ORIGINS=http://localhost:3000
